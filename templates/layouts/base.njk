<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Fictional Ecology{% endblock %}</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/components.css">
  <script src="/js/htmx.min.js" defer></script>
  <script src="/js/alpine.min.js" defer></script>
  <script src="/js/lucide.min.js"></script>
  {% block head %}{% endblock %}
</head>
<body hx-boost="true">
  <div id="page-progress"></div>
  <header class="top-bar">
    <a href="/worlds" class="logo">
      <span class="logo-icon" aria-hidden="true">&#9672;</span>
      <span class="logo-text">Fictional Ecology</span>
    </a>
    {% if world %}
    <div class="search-container" x-data="{ open: false }">
      <input type="search" name="q" placeholder="Search {{ world.name }}..."
        hx-get="/worlds/{{ world.id }}/search"
        hx-trigger="input changed delay:300ms"
        hx-target="#search-results"
        hx-indicator="#search-spinner"
        @focus="open = true"
        @click.outside="open = false"
        autocomplete="off">
      <span id="search-spinner" class="htmx-indicator" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:0.8rem">...</span>
      <div id="search-results" class="search-dropdown" x-show="open"></div>
    </div>
    {% endif %}
    <nav class="top-nav">
      {% if world %}
      <a href="/worlds/{{ world.id }}" class="nav-link">Dashboard</a>
      <a href="/worlds/{{ world.id }}/graph" class="nav-link">Graph</a>
      <a href="/worlds/{{ world.id }}/timeline" class="nav-link">Timeline</a>
      <a href="/worlds/{{ world.id }}/maps" class="nav-link">Maps</a>
      <a href="/worlds/{{ world.id }}/validate" class="nav-link">Validate</a>
      {% endif %}
      <a href="/worlds" class="nav-link">All Worlds</a>
      <a href="/blueprints" class="nav-link">Blueprints</a>
      <a href="/archetypes" class="nav-link">Templates</a>
      <a href="/constellations/new" class="nav-link">+ Constellation</a>
    </nav>
  </header>

  <div class="app-layout">
    {% block sidebar %}{% endblock %}
    <main class="main-content">
      {% block breadcrumbs %}{% endblock %}
      {% block content %}{% endblock %}
    </main>
  </div>

  {% block scripts %}{% endblock %}
  <script>
    document.addEventListener('DOMContentLoaded', () => lucide.createIcons());
    document.body.addEventListener('htmx:afterSwap', () => lucide.createIcons());
    (function() {
      const bar = document.getElementById('page-progress');
      if (!bar) return;
      document.body.addEventListener('htmx:beforeRequest', () => {
        bar.style.width = '0';
        bar.classList.add('active');
      });
      document.body.addEventListener('htmx:afterRequest', () => {
        bar.style.width = '100%';
        bar.style.transition = 'width 0.2s, opacity 0.4s 0.2s';
        bar.style.opacity = '0';
        setTimeout(() => {
          bar.classList.remove('active');
          bar.style.transition = '';
          bar.style.width = '0';
          bar.style.opacity = '';
        }, 600);
      });
    })();
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 's') {
        const form = document.querySelector('main form.form-card');
        if (form) { e.preventDefault(); form.requestSubmit(); }
      }
    });
    (function() {
      const form = document.querySelector('main form.form-card');
      if (!form) return;
      let dirty = false;
      form.addEventListener('input', () => { dirty = true; });
      form.addEventListener('submit', () => { dirty = false; });
      window.addEventListener('beforeunload', (e) => {
        if (dirty) { e.preventDefault(); }
      });
    })();
  </script>
</body>
</html>
