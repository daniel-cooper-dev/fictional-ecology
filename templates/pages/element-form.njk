{% extends "layouts/world.njk" %}
{% set activeDomain = domainConfig.id %}

{% block breadcrumbs %}
<nav class="breadcrumbs">
  <a href="/worlds/{{ world.id }}">{{ world.name }}</a>
  <span class="sep">/</span>
  <a href="/worlds/{{ world.id }}/{{ domainConfig.id }}">{{ domainConfig.namePlural }}</a>
  <span class="sep">/</span>
  <span>{{ "New" if isNew else element.name }}</span>
</nav>
{% endblock %}

{% block content %}
<div class="page-header">
  <h1>{{ "Create New " + domainConfig.name if isNew else "Edit " + element.name }}</h1>
</div>

{% if error %}
<div class="alert alert-error">{{ error }}</div>
{% endif %}

{% if isNew and domainConfig.archetypes and domainConfig.archetypes.length > 0 %}
<div class="archetype-picker">
  <p class="archetype-heading">Start from a template, or begin with a blank form.</p>
  <div class="onboarding-options">
    <a href="/worlds/{{ world.id }}/{{ domainConfig.id }}/new"
       class="onboarding-option{% if not selectedArchetype %} selected{% endif %}">
      <div class="opt-icon">📝</div>
      <h3>From Scratch</h3>
      <p>Start with a blank form</p>
    </a>
    {% for arch in domainConfig.archetypes %}
    <a href="/worlds/{{ world.id }}/{{ domainConfig.id }}/new?archetype={{ arch.id }}"
       class="onboarding-option{% if selectedArchetype and selectedArchetype.id == arch.id %} selected{% endif %}">
      <div class="opt-icon"><i data-lucide="{{ domainConfig.icon }}"></i></div>
      <h3>{{ arch.name }}</h3>
      <p>{{ arch.description }}</p>
    </a>
    {% endfor %}
  </div>
</div>
{% endif %}

{% if pairsWellWith and pairsWellWith.length > 0 %}
<div style="margin-bottom: 20px;">
  <h3 style="font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 8px;">Pairs Well With</h3>
  <div style="display: flex; gap: 8px; flex-wrap: wrap;">
    {% for p in pairsWellWith %}
    <a href="/worlds/{{ world.id }}/{{ p.domain }}/new?archetype={{ p.archetypeId }}"
       class="element-card" style="--domain-color: {{ p.domainColor }}; max-width: 260px; padding: 12px;">
      <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 4px;">
        <span style="color: {{ p.domainColor }}"><i data-lucide="{{ p.domainIcon }}" style="width: 14px; height: 14px;"></i></span>
        <span style="font-size: 0.7rem; font-weight: 600; text-transform: uppercase; color: {{ p.domainColor }};">{{ p.domainName }}</span>
      </div>
      <h3 style="font-size: 0.85rem; margin-bottom: 2px;">{{ p.archetypeName }}</h3>
      <p style="font-size: 0.7rem; color: var(--text-muted); font-style: italic;">{{ p.reason }}</p>
    </a>
    {% endfor %}
  </div>
</div>
{% endif %}

<form method="POST"
  action="{% if isNew %}/worlds/{{ world.id }}/{{ domainConfig.id }}{% else %}/worlds/{{ world.id }}/{{ domainConfig.id }}/{{ element.id }}{% endif %}"
  class="form-card"
  hx-boost="true">

  {# Core fields #}
  <fieldset>
    <legend>Basic Info</legend>
    <div class="form-group">
      <label for="name">Name *</label>
      <input type="text" id="name" name="name" required value="{{ element.name if element else '' }}" class="form-control" placeholder="Enter name...">
    </div>

    {% if domainConfig.elementTypes.length > 1 %}
    <div class="form-group" x-data="{ selectedType: '{{ element.element_type if element else '' }}' }">
      <label for="element_type">Type</label>
      <select id="element_type" name="element_type" class="form-control" x-model="selectedType">
        <option value="">-- Select Type --</option>
        {% for t in domainConfig.elementTypes %}
        <option value="{{ t }}" {% if element and element.element_type == t %}selected{% endif %}>
          {{ t | replace('_', ' ') | capitalize }}
        </option>
        {% endfor %}
      </select>
      {% if domainConfig.elementTypeDescriptions %}
        {% for t in domainConfig.elementTypes %}
        <p class="help-text" x-show="selectedType === '{{ t }}'" x-cloak>{{ domainConfig.elementTypeDescriptions[t] }}</p>
        {% endfor %}
      {% endif %}
    </div>
    {% endif %}

    <div class="form-group">
      <label for="summary">Summary</label>
      <input type="text" id="summary" name="summary" value="{{ element.summary if element else '' }}" class="form-control" placeholder="Brief description...">
    </div>

    <div class="form-group" x-data="{ count: {{ (element.detailed_notes | length) if element and element.detailed_notes else 0 }} }">
      <label for="detailed_notes">Detailed Notes <span class="char-count" x-text="count + ' chars'" x-show="count > 0"></span></label>
      <textarea id="detailed_notes" name="detailed_notes" rows="6" class="form-control" placeholder="Full description, lore, and details..." @input="count = $event.target.value.length">{{ element.detailed_notes if element else '' }}</textarea>
    </div>
  </fieldset>

  {# Domain-specific extension fields #}
  {% if domainConfig.fields.length > 0 %}
  <fieldset>
    <legend>{{ domainConfig.name }} Details</legend>
    {% for field in domainConfig.fields %}
      {% set val = '' %}
      {% if element and element.extension and element.extension[field.name] is defined %}
        {% set val = element.extension[field.name] %}
      {% endif %}

      <div class="form-group">
        <label for="{{ field.name }}">{{ field.label }}</label>
        {% if field.helpText %}<p class="help-text">{{ field.helpText }}</p>{% endif %}

        {% if field.type == 'select' and field.options %}
          {% if field.optionDescriptions %}
          <div x-data="{ selected: '{{ val }}' }">
            <select id="{{ field.name }}" name="{{ field.name }}" class="form-control" x-model="selected">
              <option value="">-- Select --</option>
              {% for opt in field.options %}
              <option value="{{ opt }}" {% if val == opt %}selected{% endif %}>{{ opt | replace('_', ' ') | capitalize }}</option>
              {% endfor %}
            </select>
            {% for opt, desc in field.optionDescriptions %}
            <p class="help-text option-desc" x-show="selected === '{{ opt }}'" x-cloak>{{ desc }}</p>
            {% endfor %}
          </div>
          {% else %}
          <select id="{{ field.name }}" name="{{ field.name }}" class="form-control">
            <option value="">-- Select --</option>
            {% for opt in field.options %}
            <option value="{{ opt }}" {% if val == opt %}selected{% endif %}>{{ opt | replace('_', ' ') | capitalize }}</option>
            {% endfor %}
          </select>
          {% endif %}

        {% elif field.type == 'textarea' %}
          <textarea id="{{ field.name }}" name="{{ field.name }}" rows="3" class="form-control" placeholder="{{ field.placeholder or '' }}">{{ val }}</textarea>

        {% elif field.type == 'boolean' %}
          <label class="checkbox-label">
            <input type="checkbox" id="{{ field.name }}" name="{{ field.name }}" value="1" {% if val and val != '0' and val != 'false' %}checked{% endif %}>
            <span>{{ field.label }}</span>
          </label>

        {% elif field.type == 'number' %}
          <input type="number" id="{{ field.name }}" name="{{ field.name }}" value="{{ val }}" class="form-control"
            {% if field.min is defined %}min="{{ field.min }}"{% endif %}
            {% if field.max is defined %}max="{{ field.max }}"{% endif %}
            {% if field.step is defined %}step="{{ field.step }}"{% endif %}>

        {% elif field.type == 'json' %}
          <textarea id="{{ field.name }}" name="{{ field.name }}" rows="3" class="form-control code-input" placeholder="{{ field.placeholder or '[]' }}">{{ val | json_pretty if val else '' }}</textarea>

        {% elif field.type == 'range' %}
          <div x-data="{ rangeVal: {{ val or field.min or 1 }} }">
            <input type="range" name="{{ field.name }}" id="field-{{ field.name }}"
              min="{{ field.min or 1 }}" max="{{ field.max or 10 }}"
              x-model="rangeVal"
              class="form-range">
            <output x-text="rangeVal"></output>
          </div>

        {% else %}
          <input type="text" id="{{ field.name }}" name="{{ field.name }}" value="{{ val }}" class="form-control" placeholder="{{ field.placeholder or '' }}">
        {% endif %}
      </div>
    {% endfor %}
  </fieldset>
  {% endif %}

  {# Magic Permeation fields #}
  {% if magicEnabled and domainConfig.magicPermeation %}
  <fieldset class="magic-fieldset" x-data="{ expanded: {{ 'true' if element and element.magic_aspects else 'false' }} }">
    <legend @click="expanded = !expanded" class="clickable">
      <span class="magic-indicator">&#9733;</span>
      Magical Aspects
      <span class="expand-arrow" :class="{ rotated: expanded }">&#9662;</span>
    </legend>
    <div x-show="expanded" x-transition>
      {% if domainConfig.magicPermeation.prompts.length > 0 %}
      <div class="magic-prompts">
        {% for p in domainConfig.magicPermeation.prompts %}
        <p class="prompt-item">{{ p }}</p>
        {% endfor %}
      </div>
      {% endif %}

      {% for field in domainConfig.magicPermeation.fields %}
        {% set val = '' %}
        {% if element and element.magic_aspects and element.magic_aspects[field.name] is defined %}
          {% set val = element.magic_aspects[field.name] %}
        {% endif %}

        <div class="form-group">
          <label for="magic_{{ field.name }}">{{ field.label }}</label>
          {% if field.helpText %}<p class="help-text">{{ field.helpText }}</p>{% endif %}

          {% if field.type == 'select' and field.options %}
            <select id="magic_{{ field.name }}" name="magic_{{ field.name }}" class="form-control">
              <option value="">-- Select --</option>
              {% for opt in field.options %}
              <option value="{{ opt }}" {% if val == opt %}selected{% endif %}>{{ opt | replace('_', ' ') | capitalize }}</option>
              {% endfor %}
            </select>
          {% elif field.type == 'boolean' %}
            <label class="checkbox-label">
              <input type="checkbox" id="magic_{{ field.name }}" name="magic_{{ field.name }}" value="1" {% if val and val != '0' and val != 'false' %}checked{% endif %}>
              <span>{{ field.label }}</span>
            </label>
          {% elif field.type == 'textarea' %}
            <textarea id="magic_{{ field.name }}" name="magic_{{ field.name }}" rows="3" class="form-control" placeholder="{{ field.placeholder or '' }}">{{ val }}</textarea>
          {% elif field.type == 'json' %}
            <textarea id="magic_{{ field.name }}" name="magic_{{ field.name }}" rows="3" class="form-control code-input" placeholder="{{ field.placeholder or '[]' }}">{{ val | json_pretty if val else '' }}</textarea>
          {% else %}
            <input type="text" id="magic_{{ field.name }}" name="magic_{{ field.name }}" value="{{ val }}" class="form-control" placeholder="{{ field.placeholder or '' }}">
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </fieldset>
  {% endif %}

  <div class="form-actions">
    <a href="/worlds/{{ world.id }}/{{ domainConfig.id }}" class="btn btn-ghost">Cancel</a>
    <button type="submit" class="btn btn-primary">{{ "Create" if isNew else "Save Changes" }}</button>
  </div>
</form>
{% endblock %}
