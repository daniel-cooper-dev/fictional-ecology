{% extends "layouts/world.njk" %}

{% block content %}
<div class="page-header">
  <div>
    <h1>{{ world.name }}</h1>
    {% if world.tagline %}<p class="subtitle">{{ world.tagline }}</p>{% endif %}
    {% if constellation %}
    <a href="/constellations/{{ constellation.id }}" style="display: inline-flex; align-items: center; gap: 6px; font-size: 0.8rem; color: var(--text-muted); text-decoration: none; margin-top: 4px;">
      <span style="background: {{ constellation.color }}; width: 8px; height: 8px; border-radius: 50%; display: inline-block;"></span>
      {{ constellation.name }}
    </a>
    {% endif %}
  </div>
  <div class="header-actions" x-data="{ showSettings: false }">
    <button class="btn btn-ghost" @click="showSettings = !showSettings">Settings</button>
    <div class="settings-panel" x-show="showSettings" @click.outside="showSettings = false" @keydown.escape.window="showSettings = false" x-transition>
      <form method="POST" action="/worlds/{{ world.id }}/settings">
        <div class="form-group">
          <label>Name</label>
          <input type="text" name="name" value="{{ world.name }}" class="form-control">
        </div>
        <div class="form-group">
          <label>Tagline</label>
          <input type="text" name="tagline" value="{{ world.tagline }}" class="form-control">
        </div>
        <div class="form-group">
          <label>Description</label>
          <textarea name="description" rows="3" class="form-control">{{ world.description }}</textarea>
        </div>
        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" name="magic_enabled" {% if world.magic_enabled %}checked{% endif %}>
            <span>Enable Magic</span>
          </label>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Save</button>
      </form>
    </div>
  </div>
</div>

{% if world.description %}
<div class="card mb-4">
  <p>{{ world.description }}</p>
</div>
{% endif %}

<h2 class="section-title">World Domains</h2>
<div class="domain-grid">
  {% for d in domains %}
    {% if d.category != 'magic' or magicEnabled %}
    <a href="/worlds/{{ world.id }}/{% if d.id == 'magic_systems' %}magic{% else %}{{ d.id }}{% endif %}" class="domain-card" style="--domain-color: {{ d.color }}">
      <div class="domain-card-header">
        <span class="domain-icon"><i data-lucide="{{ d.icon }}"></i></span>
        <span class="domain-count">{{ stats[d.id] or 0 }}</span>
      </div>
      <h3>{{ d.name }}</h3>
      <p class="domain-desc">{{ d.description | truncate(80) }}</p>
      {% if d.archetypes and d.archetypes.length > 0 %}
      <span style="font-size: 0.65rem; color: var(--text-muted); margin-top: 4px;">{{ d.archetypes.length }} templates</span>
      {% endif %}
    </a>
    {% endif %}
  {% endfor %}
</div>

{% if blueprint %}
<div style="margin-top: 32px;" x-data="{ open: true }">
  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
    <span style="color: {{ blueprint.color }}"><i data-lucide="{{ blueprint.icon }}"></i></span>
    <h2 class="section-title" style="margin: 0;">Blueprint: {{ blueprint.name }}</h2>
    <button class="btn btn-ghost btn-sm" @click="open = !open" x-text="open ? 'Hide' : 'Show'" style="margin-left: auto;"></button>
  </div>
  <div x-show="open" x-transition>
    <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 16px;">{{ blueprint.description }}</p>
    <div class="element-grid">
      {% for s in blueprintSuggestions %}
      <a href="/worlds/{{ world.id }}/{% if s.domain == 'magic_systems' %}magic{% else %}{{ s.domain }}{% endif %}/new{% if s.archetype %}?archetype={{ s.archetypeId }}{% endif %}"
         class="element-card" style="--domain-color: {{ s.domainColor }};">
        <div class="element-card-header" style="display: flex; justify-content: space-between; align-items: center;">
          <span style="display: flex; align-items: center; gap: 4px; color: {{ s.domainColor }}; font-size: 0.7rem; font-weight: 600; text-transform: uppercase;">
            <i data-lucide="{{ s.domainIcon }}" style="width: 14px; height: 14px;"></i>
            {{ s.domainName }}
          </span>
          <span class="badge" style="font-size: 0.6rem;
            {% if s.priority == 'essential' %}background: var(--accent); color: white;
            {% elif s.priority == 'recommended' %}background: var(--bg-tertiary); color: var(--text-secondary);
            {% else %}background: transparent; color: var(--text-muted); border: 1px solid var(--border-color);
            {% endif %}">{{ s.priority }}</span>
        </div>
        {% if s.archetype %}
        <h3 style="font-size: 0.9rem; margin-top: 4px;">{{ s.archetype.name }}</h3>
        <p style="font-size: 0.75rem; color: var(--text-muted);">{{ s.archetype.description | truncate(80) }}</p>
        {% else %}
        <h3 style="font-size: 0.9rem; margin-top: 4px; color: var(--text-muted);">{{ s.archetypeId | replace('_', ' ') | capitalize }}</h3>
        {% endif %}
      </a>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

<div class="dashboard-footer">
  <div style="display:flex; gap:8px; margin-bottom:16px">
    <a href="/worlds/{{ world.id }}/export/json" class="btn btn-ghost btn-sm" download>Export JSON</a>
    <a href="/worlds/{{ world.id }}/export/markdown" class="btn btn-ghost btn-sm" download>Export Markdown</a>
  </div>
  <form method="POST" action="/worlds/{{ world.id }}/delete"
    onsubmit="return confirm('Delete this world and all its data? This cannot be undone.')">
    <button type="submit" class="btn btn-danger btn-sm">Delete World</button>
  </form>
</div>
{% endblock %}
