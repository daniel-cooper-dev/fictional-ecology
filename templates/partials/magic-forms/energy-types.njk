<div class="form-group">
  <label for="name">Name</label>
  <input type="text" id="name" name="name" value="{{ item.name if item else '' }}" class="form-control" required>
</div>

<div class="form-group">
  <label for="particle_name">Particle Name</label>
  <input type="text" id="particle_name" name="particle_name" value="{{ item.particle_name if item else '' }}" class="form-control">
</div>

<div class="form-group">
  <label class="checkbox-label">
    <input type="checkbox" id="is_quasi_physical" name="is_quasi_physical" value="1" {% if item and item.is_quasi_physical %}checked{% endif %}>
    <span>Is Quasi-Physical</span>
  </label>
</div>

<div class="form-group">
  <label class="checkbox-label">
    <input type="checkbox" id="measurable" name="measurable" value="1" {% if item and item.measurable %}checked{% endif %}>
    <span>Measurable</span>
  </label>
</div>

<div class="form-group">
  <label for="unit_of_measurement">Unit of Measurement</label>
  <input type="text" id="unit_of_measurement" name="unit_of_measurement" value="{{ item.unit_of_measurement if item else '' }}" class="form-control">
</div>

<div class="form-group">
  <label for="color_visual">Color / Visual</label>
  <input type="text" id="color_visual" name="color_visual" value="{{ item.color_visual if item else '' }}" class="form-control">
</div>

<div class="form-group">
  <label for="visual_manifestation">Visual Manifestation</label>
  <textarea id="visual_manifestation" name="visual_manifestation" rows="3" class="form-control">{{ item.visual_manifestation if item else '' }}</textarea>
</div>

<div class="form-group">
  <label for="interaction_with_matter">Interaction with Matter</label>
  <textarea id="interaction_with_matter" name="interaction_with_matter" rows="3" class="form-control">{{ item.interaction_with_matter if item else '' }}</textarea>
</div>

<div class="form-group">
  <label for="decay_rate">Decay Rate</label>
  <input type="text" id="decay_rate" name="decay_rate" value="{{ item.decay_rate if item else '' }}" class="form-control">
</div>

<div class="form-group">
  <label class="checkbox-label">
    <input type="checkbox" id="can_be_stored" name="can_be_stored" value="1" {% if item and item.can_be_stored %}checked{% endif %}>
    <span>Can Be Stored</span>
  </label>
</div>

<div class="form-group">
  <label for="storage_methods">Storage Methods</label>
  <textarea id="storage_methods" name="storage_methods" rows="3" class="form-control">{{ item.storage_methods if item else '' }}</textarea>
</div>

<div class="form-group">
  <label for="conversion_rules">Conversion Rules <small>(JSON)</small></label>
  <textarea id="conversion_rules" name="conversion_rules" rows="4" class="form-control">{{ item.conversion_rules if item else '' }}</textarea>
</div>
